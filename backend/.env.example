# ─── Base de Datos PostgreSQL ──────────────────────────────
DATABASE_URL=postgresql+psycopg2://postgres:tu_password@localhost:5432/planilla_docentes_upds
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:tu_password@localhost:5432/planilla_docentes_upds

# ─── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ─── JWT ───────────────────────────────────────────────────
# CAMBIAR EN PRODUCCIÓN — clave secreta para tokens JWT
JWT_SECRET=cambiar-esta-clave-en-produccion

# ─── Uploads ───────────────────────────────────────────────
UPLOAD_DIR=./data/uploads

# ─── Admin Bootstrap ──────────────────────────────────────
# Contraseña para los admins por defecto: admin, daniel, pedro
# (debe cumplir: 8+ chars, 1 mayúscula, 1 minúscula, 1 número)
# Si no se configura, no se crean admins automáticamente
ADMIN_DEFAULT_PASSWORD=Admin123

# ─── Business Settings ─────────────────────────────────────
# ACTIVE_ACADEMIC_PERIOD, COMPANY_NAME, COMPANY_NIT, HOURLY_RATE
# are now configured from the admin UI (Configuración page).
# Default values are seeded on first startup.
